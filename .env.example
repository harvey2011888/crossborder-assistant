# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=bot_user
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=crossborder_bot

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
DASHSCOPE_API_KEY=your_qianwen_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default AI Provider (gemini/qianwen/openai)
DEFAULT_AI_PROVIDER=gemini

# Platform API Configuration (待接口文档)
PLATFORM_API_URL=https://your-platform.com/api
PLATFORM_API_KEY=your_platform_api_key_here

# Taobao API Configuration
TAOBAO_APP_KEY=your_taobao_app_key_here
TAOBAO_APP_SECRET=your_taobao_app_secret_here
TAOBAO_API_URL=https://api.onebound.cn/taobao  # 第三方API地址（可选）

# JD API Configuration
JD_APP_KEY=your_jd_app_key_here
JD_APP_SECRET=your_jd_app_secret_here
JD_API_URL=https://api.onebound.cn/jd  # 第三方API地址（可选）

# Bot Configuration
BOT_PREFIX=/
BOT_LANGUAGE=zh-CN
LOG_LEVEL=INFO
